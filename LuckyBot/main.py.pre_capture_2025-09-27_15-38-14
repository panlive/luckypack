def load_client(user_id: str) -> dict | None:
    try:
        path = _client_json_path(user_id)
        if not os.path.exists(path):
            return None
        with open(path, 'r', encoding='utf-8') as f:
            return json.load(f)
    except Exception as e:
        # не падаем на читающей ошибке — логируем и возвращаем None
        try:
            asyncio.create_task(notify_admin(f"load_client error: {e}"))
        except Exception:
            pass
        return None


def save_client(client: dict) -> None:
    user_id = str(client.get('user_id'))
    assert user_id and user_id.isdigit(), 'client.user_id должен быть числовым'
    path = _client_json_path(client['user_id'])
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = f"{path}.tmp"
    with open(tmp, 'w', encoding='utf-8') as f:
        json.dump(client, f, ensure_ascii=False, indent=2)
    os.replace(tmp, path)

