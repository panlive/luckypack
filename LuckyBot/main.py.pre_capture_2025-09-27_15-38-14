# === Абсолютный путь для клиентских JSON (вне App) ===
LP_CLIENTS_DIR = os.environ.get('LP_CLIENTS_DIR', '/srv/luckypack/data/clients')

def _client_json_path(uid):
    base = os.path.realpath(LP_CLIENTS_DIR)
    if '/srv/luckypack/App/' in base:
        raise RuntimeError(f'Invalid LP_CLIENTS_DIR inside App: {base}')
    return os.path.join(base, f'{uid}.json')

