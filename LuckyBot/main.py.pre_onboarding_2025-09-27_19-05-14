#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
LuckyBot/main.py — основной исполняемый модуль Telegram‑бота LuckyPackBot (aiogram v2)

Задачи:
  • Инициализация бота, диспетчера и памяти FSM
  • Регистрация обработчиков (в т.ч. глобальный ловец контактов capture_contact)
  • Безопасное файловое хранилище профилей клиентов (JSON) СТРОГО вне App
  • Рантайм‑гард: запрет папок data/Data внутри App (кроме белого списка)
  • Аккуратные уведомления админу при критических ошибках

ВАЖНО (инварианты путей):
  • Единственный валидный каталог данных: /srv/luckypack/data
  • Любые data/Data внутри /srv/luckypack/App ЗАПРЕЩЕНЫ, кроме whitelist:
       /srv/luckypack/App/LuckyPricer/data

Зависимости по проекту:
  • config.py:   TELEGRAM_BOT_TOKEN, SUPERADMIN_ID
  • admin_notify.py: notify_admin(text: str)
  • handlers/*: модульные обработчики; capture_contact.register(dp) — глобальный ловец телефона/e‑mail

Файл написан с упором на надёжность: атомарные записи, защита от неверных путей, мягкие падения модулей.
"""
from __future__ import annotations

import os
import sys
import json
import asyncio
import traceback
from pathlib import Path
from typing import Optional, Dict, Any

from dotenv import load_dotenv
from aiogram import Bot, Dispatcher, types
from aiogram.utils import executor
from aiogram.contrib.fsm_storage.memory import MemoryStorage

# -----------------------------------------------------------------------------
# 1) PYTHONPATH и базовые константы
# -----------------------------------------------------------------------------
PROJECT_ROOT = "/srv/luckypack/App"
if PROJECT_ROOT not in sys.path:
    sys.path.insert(0, PROJECT_ROOT)

ROOT = Path("/srv/luckypack").resolve()
APP_DIR = ROOT / "App"
DATA_DIR = Path(os.environ.get("LP_DATA_DIR", "/srv/luckypack/data")).resolve()

# Единственный допустимый каталог данных снаружи App
LP_CLIENTS_DIR = Path(os.environ.get("LP_CLIENTS_DIR", str(DATA_DIR / "clients"))).resolve()

# Белый список внутренних data, допускается только LuckyPricer/data
APP_DATA_WHITELIST = {str((APP_DIR / "LuckyPricer" / "data").resolve())}

# Разрешено отключить рантайм‑гард для отладки: LP_DISABLE_RUNTIME_GUARD=1
DISABLE_GUARD = os.environ.get("LP_DISABLE_RUNTIME_GUARD") == "1"

# -----------------------------------------------------------------------------
# 2) Рантайм‑гард: запрещаем любые App/**/data|Data (кроме whitelist)
# -----------------------------------------------------------------------------
def guard_no_app_data_runtime() -> None:
    if DISABLE_GUARD:
        return
    bad: list[str] = []
    for dirpath, dirnames, _ in os.walk(str(APP_DIR)):
        base = os.path.basename(dirpath)
        if base.lower() == "data":
            real = str(Path(dirpath).resolve())
            # пропускаем whitelist
            skip = any(real == w or real.startswith(w + os.sep) for w in APP_DATA_WHITELIST)
            if not skip:
                bad.append(real)
    if bad:
        red = "\033[1;31m"; yel = "\033[1;33m"; rst = "\033[0m"
        sys.stderr.write(f"{red}🚫 RUNTIME BLOCKED{rst} — запрещены каталоги 'data' внутри App (кроме whitelist)\n")
        sys.stderr.write(f"{yel}Найдены:{rst}\n" + "\n".join(f"  • {p}" for p in bad) + "\n")
        sys.stderr.write(f"Разрешён: {DATA_DIR}\nWhitelist:\n" + "\n".join(f"  • {w}" for w in APP_DATA_WHITELIST) + "\n")
        raise SystemExit(1)

# Запускаем проверку ПЕРЕД инициализацией бота
guard_no_app_data_runtime()

# -----------------------------------------------------------------------------
# 3) Импорты проекта (после фикса PYTHONPATH)
# -----------------------------------------------------------------------------
try:
    from config import TELEGRAM_BOT_TOKEN, SUPERADMIN_ID
except Exception as e:
    print(f"ERR: config import failed: {e}", file=sys.stderr)
    raise

# Уведомления админу (не роняем при отсутствии — просто заглушка)
try:
    from admin_notify import notify_admin  # def notify_admin(text: str) -> Awaitable
except Exception:
    async def notify_admin(text: str) -> None:  # type: ignore
        # запасная тихая заглушка, чтобы не падать
        sys.stderr.write(f"[admin_notify STUB] {text}\n")

# Не делаем жёстких импортов FSM‑состояний, чтобы файл не падал, если они двигаются
try:
    from states.registration_states import Registration  # type: ignore
except Exception:
    class Registration:  # type: ignore
        pass

# Опциональное меню (поддержка старого/нового расположения)
def _load_main_menu_keyboard():
    try:
        from keyboards.main_menu import main_menu_keyboard as _raw
        return (lambda: _raw()) if callable(_raw) else (lambda: _raw)
    except Exception:
        try:
            from LuckyBot.keyboards.main_menu import main_menu_keyboard as _raw2
            return (lambda: _raw2()) if callable(_raw2) else (lambda: _raw2)
        except Exception:
            return (lambda: None)

main_menu_keyboard = _load_main_menu_keyboard()

# -----------------------------------------------------------------------------
# 4) Безопасное файловое хранилище клиентов (JSON)
# -----------------------------------------------------------------------------
def _client_json_path(uid: int | str) -> Path:
    base = LP_CLIENTS_DIR
    # Жёсткая защита: запрещаем запись внутрь App
    if str(base).startswith(str(APP_DIR)):
        raise RuntimeError(f"Invalid LP_CLIENTS_DIR inside App: {base}")
    return base / f"{uid}.json"

async def _safe_alert(msg: str) -> None:
    try:
        await notify_admin(msg)
    except Exception:
        # последнее спасение — stderr
        sys.stderr.write(msg + "\n")

def load_client(user_id: int | str) -> Optional[Dict[str, Any]]:
    p = _client_json_path(user_id)
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception as e:
        # не роняем процесс, но алертим
        try:
            asyncio.get_event_loop().create_task(_safe_alert(f"load_client error: {e}"))
        except Exception:
            pass
        return None

def save_client(client: Dict[str, Any]) -> None:
    uid = str(client.get("user_id", "")).strip()
    if not uid.isdigit():
        raise ValueError("client.user_id должен быть числовым")
    p = _client_json_path(uid)
    p.parent.mkdir(parents=True, exist_ok=True)
    tmp = p.with_suffix(p.suffix + ".tmp")
    tmp.write_text(json.dumps(client, ensure_ascii=False, indent=2), encoding="utf-8")
    os.replace(str(tmp), str(p))  # атомарная замена

# -----------------------------------------------------------------------------
# 5) Инициализация бота/диспетчера
# -----------------------------------------------------------------------------
load_dotenv()
BOT_TOKEN = os.environ.get("TELEGRAM_BOT_TOKEN", TELEGRAM_BOT_TOKEN)
if not BOT_TOKEN:
    print("ERR: TELEGRAM_BOT_TOKEN пуст", file=sys.stderr)
    sys.exit(1)

loop = asyncio.get_event_loop()
storage = MemoryStorage()
bot = Bot(token=BOT_TOKEN)
dp = Dispatcher(bot, storage=storage)

# -----------------------------------------------------------------------------
# 6) Регистрация обработчиков (мягкая, чтобы не ронять процесс при частичной сборке)
# -----------------------------------------------------------------------------
# Кнопки/модули, которые могут отсутствовать в ранних сборках — заворачиваем в try
try:
    from LuckyBot.handlers.neighbors import register as _reg_neighbors  # type: ignore
    _reg_neighbors(dp)
except Exception:
    pass

try:
    from LuckyBot.handlers.photo_pick import register as _reg_photo_pick  # type: ignore
    _reg_photo_pick(dp)
except Exception:
    pass

try:
    from LuckyBot.handlers import prices  # type: ignore
    if hasattr(prices, "register"):
        prices.register(dp)
except Exception:
    pass

# Глобальный ловец телефона/e‑mail (capture_contact)
try:
    from LuckyBot.handlers.capture_contact import register as _reg_capture_contact  # type: ignore
    _reg_capture_contact(dp)
    print("[init] capture_contact: registered")
except Exception as e:
    print(f"[init] capture_contact: not registered: {e}")

# -----------------------------------------------------------------------------
# 7) Базовые хендлеры (пример /start)
# -----------------------------------------------------------------------------
@dp.message_handler(commands=["start"])  # type: ignore
async def cmd_start(message: types.Message) -> None:
    user_id = str(message.from_user.id)
    try:
        client = load_client(user_id)
        name = (client or {}).get("name") or (message.from_user.first_name or "друг")

        if client and client.get("is_verified"):
            txt = f"Привет, <b>{name}</b>! 👋"
            await message.answer(txt, parse_mode="HTML")
            return

        # упрощённая первая подача меню, без навязчивой регистрации
        kb = None
        try:
            kb = main_menu_keyboard()
        except Exception:
            kb = None
        await message.answer(
            "Готов к работе. Выберите действие в меню или пришлите телефон/e‑mail.",
            reply_markup=kb,
        )

    except Exception as e:
        await _safe_alert(f"/start error: {e}\n{traceback.format_exc()}")
        await message.answer("⚠️ Временная ошибка. Попробуйте позже.")

# -----------------------------------------------------------------------------
# 8) Точка входа
# -----------------------------------------------------------------------------
if __name__ == "__main__":
    # Явно печатаем ключевые пути для диагностики
    print(f"ROOT={ROOT}")
    print(f"APP_DIR={APP_DIR}")
    print(f"DATA_DIR={DATA_DIR}")
    print(f"LP_CLIENTS_DIR={LP_CLIENTS_DIR}")
    print(f"APP_DATA_WHITELIST={sorted(APP_DATA_WHITELIST)}")

    executor.start_polling(dp, skip_updates=True)
